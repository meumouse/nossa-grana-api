# ---- Banco de dados ----
# Em dev, sobe via `npm run db:up` (docker compose) com estas credenciais.
# Porta 5433 no host p/ não conflitar com um PostgreSQL local na 5432.
DATABASE_URL="postgresql://nossagrana:nossagrana@localhost:5433/nossagrana?schema=public"

# ---- Servidor ----
NODE_ENV=development
HOST=0.0.0.0
PORT=3333
# Origens permitidas para CORS (separadas por vírgula). Use o host do PWA.
CORS_ORIGIN="http://localhost:5173"
# Nível do log HTTP (Pino): fatal|error|warn|info|debug|trace|silent.
# Use debug/trace p/ investigar, warn p/ reduzir ruído em produção.
LOG_LEVEL=info

# ---- Auth ----
# Segredos longos e aleatórios. Gere com: openssl rand -hex 48
JWT_ACCESS_SECRET="troque-isto-access-secret-bem-longo-e-aleatorio"
JWT_REFRESH_SECRET="troque-isto-refresh-secret-bem-longo-e-aleatorio"
# Duração do access token (curto) e do refresh token (longo).
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# ---- Login com Google (opcional) ----
# Client ID OAuth do Google Cloud (APIs & Services > Credentials > OAuth client
# ID, tipo "Web application"). Mesmo valor do VITE_GOOGLE_CLIENT_ID no PWA. Sem
# ele o login com Google fica desativado (o app segue com e-mail/senha). NÃO
# precisa do client secret — só validamos o ID token usando este Client ID.
GOOGLE_OAUTH_CLIENT_ID=

# ---- Convites ----
INVITATION_TTL_DAYS=7

# ---- Cache + Fila (Redis) ----
# OPCIONAL, mas usado por duas coisas:
#  1) Cache: sem REDIS_URL roda EM MEMÓRIA (in-process), zero infra.
#  2) Fila (BullMQ): com REDIS_URL a confirmação de importação roda em background
#     (worker), evitando 500 por timeout em listas grandes. Sem ela, a
#     confirmação processa inline no request (modo legado, ok p/ listas pequenas).
# Em dev via docker compose, o Redis sobe na 6380 do host: redis://localhost:6380
# (suba com `npm run redis:up`).
REDIS_URL=
# Teto de entradas do cache em memória (ignorado no modo Redis).
CACHE_MAX_MEMORY_ENTRIES=5000
# TTLs (segundos). Membership é curto de propósito (mudanças também invalidam
# na hora); catálogo de instituições é quase estático, pode ser mais longo.
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_TTL_MEMBER_SECONDS=30
CACHE_TTL_INSTITUTIONS_SECONDS=300

# ---- E-mail transacional (Resend) ----
# URL pública do PWA — base dos links de reset/verificação enviados por e-mail.
APP_URL="http://localhost:5173"
# Chave da API do Resend: https://resend.com/api-keys (OPCIONAL).
# Sem ela, os e-mails transacionais são apenas logados e pulados — o app
# funciona normalmente, só não envia recuperação de senha/verificação/boas-vindas.
RESEND_API_KEY=
# Remetente "Nome <endereco@dominio>". O domínio precisa estar verificado no
# Resend; em testes use o sandbox onboarding@resend.dev.
RESEND_FROM="Nossa Grana <onboarding@resend.dev>"
# Validade dos tokens enviados por e-mail.
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_VERIFICATION_TTL_HOURS=24

# ---- Importação por LLM ----
# Provider de extração de documentos (extrato/fatura/comprovante).
# Opções: openai | anthropic | google. Default: openai.
# Cada workspace pode sobrescrever provider/modelo/chave em Configurações.
LLM_PROVIDER=openai
# Modelo default do provider de env (precisa suportar visão p/ ler imagem/PDF).
LLM_MODEL=gpt-4o
# Chave de API por provider — necessária a do provider em uso (senão a
# importação por IA falha até configurar aqui ou nas Configurações do workspace).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Limite (MB) do documento enviado para importação.
IMPORT_MAX_FILE_MB=15

# ---- Object storage (S3-compatível) ----
# Guarda os documentos enviados à IA e os comprovantes das transações.
# OPCIONAL: sem S3_BUCKET o storage fica desligado e a API segue funcionando
# (a importação por IA processa o arquivo em memória, só não o persiste).
# Funciona com AWS S3, Cloudflare R2 e MinIO.
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Endpoint custom p/ R2/MinIO. Vazio = AWS S3. Ex. R2:
#   https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT=
# MinIO exige path-style (bucket no path, não no subdomínio). AWS/R2 = false.
S3_FORCE_PATH_STYLE=false
# Validade (segundos) das URLs assinadas de download/upload.
S3_PRESIGN_TTL_SECONDS=900
